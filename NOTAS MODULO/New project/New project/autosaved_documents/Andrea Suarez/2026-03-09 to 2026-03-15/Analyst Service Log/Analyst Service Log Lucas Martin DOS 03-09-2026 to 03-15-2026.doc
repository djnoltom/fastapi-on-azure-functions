<!doctype html>
<html><head><meta charset="utf-8"><title>Analyst Service Log</title><style>body{font-family:'Open Sans',Helvetica,Arial,sans-serif;margin:0;background:#f4f5f7;color:#222;}.page{max-width:980px;margin:24px auto;background:#fff;padding:28px 34px;box-shadow:0 6px 28px rgba(0,0,0,.08);}.header{display:grid;grid-template-columns:240px 1fr;gap:18px;align-items:center;margin-bottom:18px;}.header img{max-width:140px;justify-self:end;}.org{font-size:14px;line-height:1.5;}.org strong{display:block;font-size:18px;margin-bottom:4px;}.doc-title{text-align:center;font-size:24px;font-weight:700;letter-spacing:.04em;margin:16px 0 18px;}.section-title{background:#e2e2e2;padding:8px 10px;font-weight:700;font-size:14px;}table{width:100%;border-collapse:collapse;margin:0 0 16px;}td,th{border:1px solid #cfd4dc;padding:8px 10px;vertical-align:top;font-size:13px;}.label{font-weight:700;display:block;margin-bottom:4px;}.content{white-space:pre-wrap;line-height:1.6;border:1px solid #d7dfeb;padding:18px;background:#fff;}.signature-grid{display:grid;grid-template-columns:1fr 1fr;gap:30px;margin-top:24px;}.signature-box{min-height:96px;display:flex;flex-direction:column;justify-content:flex-end;}.signature-line{border-top:1px solid #222;padding-top:6px;margin-top:16px;font-size:13px;}.muted{color:#5c6878;}</style></head><body><div class="page"><div class="header"><img src="https://s3.amazonaws.com/uploads.officepuzzle.com/business_units/6675d76c68796b6e040fb608/Colorful-Cute-Rainbow-Baby-Clothes-Logo-Hoodies-Blue-hope-Tampa-17189993797613.png" alt="Blue Hope"><div class="org"><strong>Blue Hope Behavioral (Tampa)</strong>804 NICHOLAS PKWY EAST SUITE 2F<br>CAPE CORAL, FL, 33990<br>Phone: +1 (786) 567-1452 | Fax: 786-904-0045<br>Email: bhbsubmit@bluehopebehavioral.com</div></div><div class="doc-title">SERVICE LOG</div><div class="muted">2026-03-09 al 2026-03-15</div><div class="muted"></div><table><tr><td colspan="12" class="section-title">Recipient and Provider</td></tr><tr><td colspan="3"><span class="label">Recipient:</span></td><td colspan="3"><span class="label">Insurance:</span></td><td colspan="3"><span class="label">Diagnoses:</span></td><td colspan="3"><span class="label">Provider:</span></td></tr><tr><td colspan="3"><span class="label">Credentials:</span></td><td colspan="2"><span class="label">PA #:</span></td><td colspan="2"><span class="label">PA Start Date:</span></td><td colspan="2"><span class="label">PA End Date:</span></td><td colspan="3"><span class="label">Approved Units:</span></td></tr></table><table><tr><th>DATE</th><th>TIME IN</th><th>TIME OUT</th><th>HOURS</th><th>UNITS</th><th>PLACE OF SERVICE</th><th>CLIENT/CAREGIVER NAME</th><th>CLIENT/CAREGIVER SIGNATURE</th></tr></table><table><tr><td><span class="label">TOTAL HOURS</span></td><td><span class="label">TOTAL UNITS</span></td><td><span class="label">TOTAL FACTURADO</span></td><td><span class="label">TOTAL DAYS</span></td></tr></table><div class="signature-grid"><div class="signature-box"><div></div><div class="signature-line">CLIENT/CAREGIVER SIGNATURE</div></div><div class="signature-box"><div></div><div class="signature-line">SIGNATURE DATE</div></div><div class="signature-box"><div></div><div class="signature-line">PROVIDER/RBT SIGNATURE</div></div><div class="signature-box"><div></div><div class="signature-line">SIGNATURE DATE</div></div></div><div class="content" style="margin-top:18px;"><span class="label">Notes:</span></div></div></body></html>